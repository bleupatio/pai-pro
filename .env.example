# pai-pro — env template.
#
# The embedded terminal runs the coding agent selected for each project.
# New projects default to Claude Code; set PAI_DEFAULT_AGENT_ID=codex to
# make new projects use Codex CLI instead.
#
# One provider, PAI Lite, covers every capability (image, video, voice,
# asset uploads). Generated assets are mirrored into
# projects/<id>/assets/ and served back to the browser by the viewer
# — no cloud bucket / object storage in the loop. For video refs,
# ./start.sh auto-launches a Cloudflare quick tunnel (see below).
#
# Without PAI_KEY set, the media CLIs fail at call time with a clean
# infra-class error; the canvas, terminal, and notes still work.

# --- PAI Lite (image + video + voice + asset upload) ---
# Get your key at https://pai-pro.utopaistudios.com/keys.
# Format: PAI_<random>.
PAI_KEY=

# --- Project agent ---
# Supported values: claude, codex. Existing projects keep their saved
# agent_id; this only affects projects created after the viewer starts.
# PAI_DEFAULT_AGENT_ID=claude

# Optional override of the PAI Lite API base. Defaults to the pinned dev
# endpoint baked into server/pai_client.js. Set this when targeting a
# different deploy (staging, prod, your own fork).
# PAI_API_BASE=https://api.pai-pro.utopaistudios.com

# --- Local ports ---
# Override per clone to run multiple instances of this repo side-by-side
# on the same machine. Leave blank to use the defaults (7488 / 7443).
# start.sh derives WEB_ORIGIN and VITE_VIEWER_URL from these, so you
# don't have to.
VIEWER_PORT=7488
WEB_PORT=7443

# --- Optional: own tunnel for video reference uploads ---
# Video gen uploads reference images / audio / video via PAI's `jm-assets`
# endpoint, which fetches each ref from a publicly-reachable URL server-side.
# ./start.sh auto-launches `cloudflared tunnel` and writes the public URL
# to .tunnel_url. Set this if you want to use your own tunnel (ngrok, paid
# Cloudflare named tunnel) instead — start.sh skips the auto-launch.
# PUBLIC_VIEWER_URL=

# --- Docker only (ignored by ./start.sh) ---
# Host-side port the Docker viewer is mapped to. Default 7588 so a host
# `./start.sh` on 7488 can coexist with `docker compose up`. Set to 7488
# if you're not running the host viewer in parallel.
# HOST_VIEWER_PORT=7588
