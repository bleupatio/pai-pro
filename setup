#!/usr/bin/env bash
# pai-pro / setup
#
# Installs pai-pro skills into Claude Code's user-scope skills dir
# (~/.claude/skills/) by symlinking each skills/<name>/ into place.
#
# Usage:
#   ./setup                  install (idempotent)
#   ./setup --force          overwrite existing files
#   ./setup --uninstall      remove the symlinks

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_SRC="$REPO_DIR/skills"
TARGET_DIR="${HOME}/.claude/skills"

FORCE=0
UNINSTALL=0
for arg in "$@"; do
  case "$arg" in
    --force)     FORCE=1 ;;
    --uninstall) UNINSTALL=1 ;;
    -h|--help)   sed -n '2,11p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)           echo "unknown arg: $arg" >&2; exit 2 ;;
  esac
done

[[ -d "$SKILLS_SRC" ]] || { echo "error: $SKILLS_SRC not found" >&2; exit 1; }
mkdir -p "$TARGET_DIR"

names=()
for d in "$SKILLS_SRC"/*/; do
  [[ -d "$d" ]] && names+=("$(basename "$d")")
done
[[ ${#names[@]} -gt 0 ]] || { echo "error: no skills in $SKILLS_SRC" >&2; exit 1; }

action_count=0
for name in "${names[@]}"; do
  src="$SKILLS_SRC/$name"
  dst="$TARGET_DIR/$name"

  if (( UNINSTALL )); then
    if [[ -L "$dst" ]]; then
      rm "$dst"
      echo "removed  $name"
      action_count=$(( action_count + 1 ))
    fi
    continue
  fi

  if [[ -L "$dst" && "$(readlink "$dst")" == "$src" ]]; then
    echo "ok       $name"
    continue
  fi

  if [[ -e "$dst" || -L "$dst" ]]; then
    if (( FORCE )); then
      rm -rf "$dst"
    else
      echo "skip     $name  (exists; rerun with --force)"
      continue
    fi
  fi

  ln -s "$src" "$dst"
  echo "linked   $name"
  action_count=$(( action_count + 1 ))
done

echo
if (( UNINSTALL )); then
  echo "uninstalled $action_count skills from $TARGET_DIR"
else
  echo "installed $action_count new skills (out of ${#names[@]} total) into $TARGET_DIR"
  echo "open a new Claude Code session to load them"
fi
